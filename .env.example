# Supabase — create a project at https://supabase.com and paste your keys here.
# Copy this file to .env and fill in your values.
# Without these, the app runs in dev mode with mock auth (no persistence).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Dev mode only (no Supabase configured): comma-separated emails that should sign in
# as Village HQ admin instead of a regular founder. Every other dev login defaults to
# 'founder'. Has no effect once Supabase is configured — set role via user_metadata there.
VITE_DEV_ADMIN_EMAILS=admin@culo.test
