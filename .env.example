# Supabase — create a project at https://supabase.com and paste your keys here.
# Copy this file to .env and fill in your values.
# Without these, the app runs in dev mode with mock auth (no persistence).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
